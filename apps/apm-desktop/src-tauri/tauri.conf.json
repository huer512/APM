{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "APM Desktop",
  "version": "0.1.0",
  "identifier": "com.apm.desktop",
  "build": {
    "beforeDevCommand": "APM_DESKTOP_DEV=1 npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "APM Desktop",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "deb", "rpm"],
    "resources": {
      "resources/runtime": "runtime",
      "resources/daemon": "daemon",
      "../../../examples/minimal": "examples/minimal"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
